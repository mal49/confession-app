{
  "name": "confession-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "frontend",
    "worker"
  ],
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:worker": "cd worker && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "build:worker": "cd worker && npm run build",
    "deploy:worker": "cd worker && npm run deploy",
    "db:create": "cd worker && wrangler d1 create confession-db",
    "db:migrate": "cd worker && wrangler d1 migrations apply confession-db"
  },
  "devDependencies": {
    "wrangler": "^3.0.0"
  }
}
