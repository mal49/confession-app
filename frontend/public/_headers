# Cloudflare Pages Headers

# All HTML files - no cache (always fetch fresh)
/*.html
  Cache-Control: public, max-age=0, must-revalidate
  Pragma: no-cache
  Expires: 0

# Root path - no cache
/
  Cache-Control: public, max-age=0, must-revalidate
  Pragma: no-cache
  Expires: 0

# Service worker - no cache (important!)
/service-worker.js
  Cache-Control: public, max-age=0, must-revalidate
  Pragma: no-cache
  Expires: 0

# Hashed assets (JS, CSS) - long cache (1 year)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Static assets (images, fonts) - 1 day cache with revalidation
/*.png
  Cache-Control: public, max-age=86400, must-revalidate
/*.svg
  Cache-Control: public, max-age=86400, must-revalidate
/*.jpg
  Cache-Control: public, max-age=86400, must-revalidate
/*.jpeg
  Cache-Control: public, max-age=86400, must-revalidate
/*.gif
  Cache-Control: public, max-age=86400, must-revalidate
/*.ico
  Cache-Control: public, max-age=86400, must-revalidate
/*.woff
  Cache-Control: public, max-age=86400, must-revalidate
/*.woff2
  Cache-Control: public, max-age=86400, must-revalidate

# Manifest - short cache
/manifest.json
  Cache-Control: public, max-age=3600, must-revalidate

# Default security headers for all routes
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://challenges.cloudflare.com https://*.cloudflare.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' https://confession-worker.ikhmalhanif60.workers.dev https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com; worker-src 'self' blob:;
