{
  "name": "confession-worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "tsc",
    "db:create": "wrangler d1 create confession-db",
    "db:migrate": "wrangler d1 migrations apply confession-db",
    "db:local": "wrangler d1 execute confession-db --local --file=./src/db/schema.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240320.0",
    "typescript": "^5.4.0",
    "wrangler": "^3.0.0"
  }
}
